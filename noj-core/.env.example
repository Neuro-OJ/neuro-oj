# noj-core 环境配置
# 复制此文件为 .env 并根据实际环境修改
DATABASE_URL=postgres://noj:noj@localhost:5432/noj
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=24h
REDIS_URL=redis://127.0.0.1:6379/
PORT=8000
# 管理员邮箱：运行 deno task seed 时，若 ADMIN_PASS 同时设置则自动创建并提升为管理员
ADMIN_EMAIL=
# 管理员密码（需要与 ADMIN_EMAIL 配合使用）
ADMIN_PASS=

# ── 速率限制（issue #73 登录限流）──────────────────────────
# 总开关：true=启用 / false=禁用。NOJ_ENV=test 时强制关闭
RATE_LIMIT_ENABLED=true
# IP 维度：30 秒窗口内最多 10 次登录尝试（防单 IP 暴力破解）
RATE_LIMIT_LOGIN_IP_WINDOW=30
RATE_LIMIT_LOGIN_IP_MAX=10
# 账号维度：30 秒窗口内最多 5 次登录尝试（防分布式撞同一账号）
RATE_LIMIT_LOGIN_ACC_WINDOW=30
RATE_LIMIT_LOGIN_ACC_MAX=5
# 失败退避：每次失败累计 +15s 等待（下一次请求被 sleep 拦下）
RATE_LIMIT_LOGIN_BACKOFF_SEC=15
# 失败锁定：连续 10 次失败后账号锁 1 小时
RATE_LIMIT_LOGIN_LOCK_THRESHOLD=10
RATE_LIMIT_LOGIN_LOCK_SECONDS=3600
