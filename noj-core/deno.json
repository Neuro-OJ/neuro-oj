{
  "name": "@noj/core",
  "version": "0.1.0",
  "exports": "./src/mod.ts",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "db:generate": "deno -A npm:drizzle-kit generate --config=./drizzle.config.ts"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/": "npm:hono@^4/",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "drizzle-orm/": "npm:/drizzle-orm@0.45.2/",
    "postgres": "npm:postgres@3.4.9",
    "ioredis": "npm:ioredis@5.11.1"
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
