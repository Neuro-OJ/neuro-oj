{
  "name": "@noj/core",
  "version": "0.1.0",
  "exports": "./src/mod.ts",
  "tasks": {
    "dev": "deno run --watch --env-file=.env --allow-net --allow-env --allow-read src/main.ts",
    "start": "deno run --env-file=.env --allow-net --allow-env --allow-read src/main.ts",
    "setup": "deno task build-packages && deno task seed",
    "seed": "deno run --allow-net --allow-env --allow-read --allow-write scripts/seed.ts",
    "build-packages": "deno run --allow-read --allow-write --allow-run scripts/build-packages.ts",
    "db:generate": "deno -A npm:drizzle-kit generate --config=./drizzle.config.ts",
    "migrate": "deno run -A scripts/migrate.ts",
    "test": "deno test -A"
  },
  "imports": {
    "hono": "npm:hono@^4",
    "hono/": "npm:hono@^4/",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "drizzle-orm/": "npm:/drizzle-orm@0.45.2/",
    "postgres": "https://deno.land/x/postgresjs@v3.4.5/mod.js",
    "ioredis": "npm:ioredis@5.11.1",
    "bcryptjs": "npm:bcryptjs@^2.4.3",
    "jose": "npm:jose@^5",
    "drizzle-kit": "npm:drizzle-kit",
    "@std/encoding": "jsr:@std/encoding@^1"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "semiColons": true,
    "singleQuote": false,
    "indentWidth": 2,
    "exclude": [
      ".deno_cache"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": [
      ".deno_cache"
    ]
  }
}
