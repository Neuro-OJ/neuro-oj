# Neuro OJ 核心服务 (noj-core) 环境变量模板
# 使用方法: cp scripts/dev/env.example noj-core/.env

# ── 数据库连接 ───────────────────────────────────────────────
# PostgreSQL 连接字符串(postgres.js 格式)
DATABASE_URL=postgresql://noj:noj@localhost:5432/noj

# ── JWT 密钥(必填,至少 32 字符) ──────────────────────────────
# 启动时会校验长度,不足则 Deno.exit(1) 拒绝启动
# 生成方法: openssl rand -base64 48
JWT_SECRET=please-replace-with-at-least-32-random-characters-aaaaaa

# ── JWT 配置(可选) ───────────────────────────────────────────
# JWT_EXPIRES_IN=24h
# JWT_ISSUER=nj-core
# JWT_AUDIENCE=nj-ui

# ── 服务监听端口(可选) ───────────────────────────────────────
# PORT=8000

# ── Redis 连接(可选,默认 localhost:6379) ────────────────────
# REDIS_URL=redis://localhost:6379

# ── 存储后端 ──────────────────────────────────────────────────
# local 模式(默认,开发环境)
# STORAGE_PROVIDER=local
# SUPPORT_PACKAGE_DIR=./data/packages

# s3 模式(生产环境)
# STORAGE_PROVIDER=s3
# S3_BUCKET=noj-support-packages
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# ── 运行环境 ──────────────────────────────────────────────────
# development | production
# NOJ_ENV=development

# ── 审计日志保留天数(可选,0 = 禁用) ─────────────────────────
# AUDIT_LOG_RETENTION_DAYS=90

# ── 引导管理员(首次部署强烈推荐设置) ─────────────────────────
# 若不设置,seed 时会自动生成临时管理员(密码 24 字符随机),
# 登录后强制跳转 /change-password 修改
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASS=YourSecurePass123!