# E2E 测试环境变量配置模板
# 复制为 .env 或直接使用 docker-compose.e2e.yml 启动完整环境

# ---------- noj-core ----------
DATABASE_URL=postgres://e2e:e2e@localhost:5432/e2e_test
REDIS_URL=redis://localhost:6379
JWT_SECRET=e2e-test-secret
NOJ_RUN_E2E=1

# ---------- noj-judge ----------
# 单独运行 Rust 集成测试：
#   NOJ_RUN_E2E=1 cargo test --test e2e -- --ignored
# 确保 Docker daemon 在运行中

# ---------- noj-judge 连接 ----------
JUDGE_QUEUE=noj:judge:queue
RESULT_QUEUE=noj:judge:results
MAX_CONCURRENT=2
WORK_DIR=/tmp/noj-work

# ---------- 可选 ----------
DATABASE_POOL_MAX=5
